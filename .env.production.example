# ──────────────────────────────────────────────────────────────
# Hour Tracker — Production Environment Variables
# ──────────────────────────────────────────────────────────────
#
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to version control.
#
# ──────────────────────────────────────────────────────────────

# ── Deployment (used by deploy.sh) ───────────────────────────

# Google Cloud project ID (required)
GCP_PROJECT_ID=your-gcp-project-id

# GCP zone for the VM (default: us-central1-a)
GCP_ZONE=us-central1-a

# Domain name for the app
DOMAIN=puretrack.duckdns.org

# PostgreSQL password — must match the value in terraform.tfvars
DB_PASSWORD=CHANGE_ME

# Docker image tag (default: latest)
IMAGE_TAG=latest

# ── Application (set on VM via Terraform) ───────────────────

# PostgreSQL connection string (assembled automatically on the VM)
# DATABASE_URL=postgres://hourtracker_user:PASSWORD@postgres:5432/hourtracker

# NextAuth.js v5 encryption secret
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-secret

# Public-facing URL of the application
# AUTH_URL=https://puretrack.duckdns.org

# ── Email (optional) ────────────────────────────────────────

# SendGrid API key for transactional emails (weekly reports, invites)
# Leave empty to disable email features.
SENDGRID_API_KEY=

# ── Scheduler ───────────────────────────────────────────────

# Cloud Scheduler authenticates to /api/reports/weekly using X-Scheduler-Key.
# This is set to AUTH_SECRET by default in Terraform.
# SCHEDULER_KEY is the same as AUTH_SECRET unless overridden.
